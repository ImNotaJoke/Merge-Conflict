{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug server",
			"type": "node",
			"request": "launch",
			"cwd": "${workspaceFolder}",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run-script", "server:watch", "Thomas"],
			"env": {
				"PORT": "8080"
			},
			"skipFiles": [
				"<node_internals>/**"
			],
		},
		{
			"type": "chrome",
			"request": "launch",
			"name": "Debug Chromium",
			"url": "http://localhost:8000",
			"webRoot": "${workspaceFolder}",
			"runtimeExecutable": "/bin/chromium",
			// Dossier de stockage du profil de Chrome en mode debug :
			// Permet de conserver la config et les extensions chrome d'un TP à l'autre (utile pour les react developer tools par ex.).
			// Adaptez si besoin le chemin vers le dossier (par défaut crée un dossier "à côté" du tp)
			"userDataDir": "${workspaceFolder}/../vscode-chrome-profile"
		},
		{
			"name": "Debug Chrome",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:8000",
			"webRoot": "${workspaceFolder}",
			"userDataDir": "${workspaceFolder}/../vscode-chrome-profile"
		}
	]
}
